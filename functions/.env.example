# คัดลอกไฟล์นี้เป็นชื่อ ".env" (ในโฟลเดอร์ functions เดียวกัน) แล้วกรอกค่าจริง
# ห้าม commit ไฟล์ .env ขึ้น git หรือส่งให้ใครเด็ดขาด

# Channel secret จาก LINE Developers Console > ตะวันฟาร์ม Provider > ช่อง Basic settings
LINE_CHANNEL_SECRET=

# Channel access token (long-lived) จากแท็บ Messaging API ในช่องเดียวกัน
LINE_CHANNEL_ACCESS_TOKEN=

# Group ID ของกลุ่มไลน์พนักงานที่จะรับสรุปประจำวัน (ค่านี้ยืนยันแล้วจากการทดสอบ webhook)
LINE_GROUP_ID=Cca829fc7c0f943bd0f9d44e6e65694fc
